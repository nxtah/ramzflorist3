generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Bouquet {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  price       Float
  images      String[]
  stock       Int      @default(0)
  isFeatured  Boolean  @default(false)
  category    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
}

model SiteConfig {
  id              Int      @id @default(1)
  siteName        String   @default("Ramz Florist")
  siteDescription String   @default("Elegant Florist & Bouquet Shop")
  bannerText      String   @default("Welcome to Ramz Florist!")
  bannerActive    Boolean  @default(false)
  aboutImages     String[]
  updatedAt       DateTime @updatedAt
}
